            "outputs": [
                {
                    "data": {
                        "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\">And we can use a reporting utility to see the results.</span></span>"
                    },
                    "type": "data"
                }
            ]
